INSERT INTO sat_tests (title, description, test_type, difficulty, length, section, is_official, time_limit_minutes, questions) VALUES ('OpenSAT Math - Easy Set 9','Official-style SAT Math practice (Easy) from OpenSAT — image-free questions only.','math','easy','short','math',true,31,'[{"id": "opensat-math-spr-541", "text": "A customer spent dollar sign 27 to purchase oranges at dollar sign 3 per pound. How many pounds of oranges did the customer purchase?", "type": "grid_in", "topic": "math", "section": "math", "correct_answer": "9", "difficulty": "easy", "explanation": "The correct answer is 9. It\u2019s given that the customer spent dollar sign 27 to purchase oranges at dollar sign 3 per pound. Therefore, the number of pounds of oranges the customer purchased is dollar sign 27 left parenthesis StartFraction 1 pound Over dollar sign 3 EndFraction right parenthesis, or 9 pounds."}, {"id": "opensat-math-spr-546", "text": "x plus 40 equals 95\nWhat value of x is the solution to the given equation?", "type": "grid_in", "topic": "math", "section": "math", "correct_answer": "55", "difficulty": "easy", "explanation": "The correct answer is 55. Subtracting 40 from both sides of the given equation yields x equals 55. Therefore, the value of x is 55."}, {"id": "opensat-math-spr-563", "text": "Out of 300 seeds that were planted, 80 percent sign sprouted. How many of these seeds sprouted?", "type": "grid_in", "topic": "math", "section": "math", "correct_answer": "240", "difficulty": "easy", "explanation": "The correct answer is 240. It\u2019s given that 80 percent sign of the 300 seeds sprouted. Therefore, the number of seeds that sprouted can be calculated by multiplying the number of seeds that were planted by StartFraction 80 Over 100 EndFraction, which gives 300 left parenthesis StartFraction 80 Over 100 EndFraction right parenthesis, or 240."}, {"id": "opensat-math-spr-565", "text": "The equation 46 equals 2 a plus 2 b gives the relationship between the side lengths a and b of a certain parallelogram. If a equals 9, what is the value of b?", "type": "grid_in", "topic": "math", "section": "math", "correct_answer": "14", "difficulty": "easy", "explanation": "The correct answer is 14. It''s given that the equation 46 equals 2 a plus 2 b gives the relationship between the side lengths a and b of a certain parallelogram. Substituting 9 for a in the given equation yields 46 equals 2 left parenthesis 9 right parenthesis plus 2 b, or 46 equals 18 plus 2 b. Subtracting 18 from both sides of this equation yields 28 equals 2 b. Dividing both sides of this equation by 2 yields 14 equals b. Therefore, if a equals 9, the value of b is 14."}, {"id": "opensat-math-spr-566", "text": "f left parenthesis x right parenthesis equals 7 x plus 1\nThe function gives the total number of people on a company retreat with x managers. What is the total number of people on a company retreat with 7 managers?", "type": "grid_in", "topic": "math", "section": "math", "correct_answer": "50", "difficulty": "easy", "explanation": "The correct answer is 50. It''s given that the function f gives the total number of people on a company retreat with x managers. It''s also given that 7 managers are on the company retreat. Substituting 7 for x in the given function yields f left parenthesis 7 right parenthesis equals 7 left parenthesis 7 right parenthesis plus 1, or f left parenthesis 7 right parenthesis equals 50. Therefore, there are a total of 50 people on a company retreat with 7 managers."}, {"id": "opensat-math-spr-573", "text": "If 2 x equals 12, what is the value of 9 x?", "type": "grid_in", "topic": "math", "section": "math", "correct_answer": "54", "difficulty": "easy", "explanation": "The correct answer is 54. Dividing both sides of the given equation by 2 yields x equals 6. Multiplying both sides of this equation by 9 yields 9 x equals 54. Thus, the value of 9 x is 54."}, {"id": "opensat-math-spr-587", "text": "If 2 plus x equals 60, what is the value of 16 plus 8 x?", "type": "grid_in", "topic": "math", "section": "math", "correct_answer": "480", "difficulty": "easy", "explanation": "The correct answer is 480. Multiplying both sides of the given equation by 8 yields 8 left parenthesis 2 plus x right parenthesis equals 8 left parenthesis 60 right parenthesis, or 16 plus 8 x equals 480. Therefore, if 2 plus x equals 60, the value of 16 plus 8 x is 480."}, {"id": "opensat-math-spr-593", "text": "3 x plus 21 equals 3 x plus k\nIn the given equation, k is a constant. The equation has infinitely many solutions. What is the value of k?", "type": "grid_in", "topic": "math", "section": "math", "correct_answer": "21", "difficulty": "easy", "explanation": "The correct answer is 21. It''s given that the equation 3 x plus 21 equals 3 x plus k has infinitely many solutions. If an equation in one variable has infinitely many solutions, then the equation is true for any value of the variable. Subtracting 3 x from both sides of the given equation yields k equals 21. Since this equation must be true for any value of x, the value of k is 21."}, {"id": "opensat-math-spr-594", "text": "Each side of a square has a length of 45. What is the perimeter of this square?", "type": "grid_in", "topic": "math", "section": "math", "correct_answer": "180", "difficulty": "easy", "explanation": "The correct answer is 180. The perimeter of a polygon is equal to the sum of the lengths of the sides of the polygon. It\u2019s given that each side of the square has a length of 45. Since a square is a polygon with 4 sides, the perimeter of this square is 45 plus 45 plus 45 plus 45, or 180."}, {"id": "opensat-math-spr-601", "text": "There are 170 blocks in a container. Of these blocks, 10 percent sign are green. How many blocks in the container are green?", "type": "grid_in", "topic": "math", "section": "math", "correct_answer": "17", "difficulty": "easy", "explanation": "The correct answer is 17. It''s given that there are 170 blocks in a container, and of these b
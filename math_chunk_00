INSERT INTO sat_tests (title, description, test_type, difficulty, length, section, is_official, time_limit_minutes, questions) VALUES ('OpenSAT Math - Easy Set 2','Official-style SAT Math practice (Easy) from OpenSAT — image-free questions only.','math','easy','medium','math',true,38,'[{"id": "opensat-math-mcq-68", "text": "If x equals 7, what is the value of x plus 20?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["13", "20", "27", "34"], "correct_answer": "C", "difficulty": "easy", "explanation": "Choice C is correct. It\u2019s given that x equals 7. Substituting 7 for x into the given expression x plus 20 yields 7 plus 20, which is equivalent to 27.\nChoice A is incorrect. This is the value of x plus 6.\nChoice B is incorrect. This is the value of x plus 13.\nChoice D is incorrect. This is the value of x plus 27."}, {"id": "opensat-math-mcq-70", "text": "Which expression is equivalent to 5 x squared minus 50 x y squared?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["5 x left parenthesis x minus 10 y squared right parenthesis", "5 x left parenthesis x minus 50 y squared right parenthesis", "5 x squared left parenthesis 10 x y squared right parenthesis", "5 x squared left parenthesis 50 x y squared right parenthesis"], "correct_answer": "A", "difficulty": "easy", "explanation": "Choice A is correct. Since each term of the given expression has a factor of 5 x, it can be rewritten as 5 x left parenthesis x right parenthesis minus 5 x left parenthesis 10 y squared right parenthesis, or 5 x left parenthesis x minus 10 y squared right parenthesis.\nChoice B is incorrect and may result from conceptual or calculation errors.\nChoice C is incorrect and may result from conceptual or calculation errors.\nChoice D is incorrect and may result from conceptual or calculation errors."}, {"id": "opensat-math-mcq-72", "text": "A store sells two different-sized containers of a certain Greek yogurt. The store\u2019s sales of this Greek yogurt totaled 1,277.94 dollars last month. The equation 5.48 x plus 7.30 y equals 1,277.94 represents this situation, where x is the number of smaller containers sold and y is the number of larger containers sold. According to the equation, which of the following represents the price, in dollars, of each smaller container?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["5.48", "7.30 y", "7.30", "5.48 x"], "correct_answer": "A", "difficulty": "easy", "explanation": "Choice A is correct. It''s given that the store''s sales of a certain Greek yogurt totaled 1,277.94 dollars last month. It''s also given that the equation 5.48 x plus 7.30 y equals 1,277.94 represents this situation, where x is the number of smaller containers sold and y is the number of larger containers sold. Since x represents the number of smaller containers of yogurt sold, the expression 5.48 x represents the total sales, in dollars, from smaller containers of yogurt. This means that x smaller containers of yogurt were sold at a price of 5.48 dollars each. Therefore, according to the equation, 5.48 represents the price, in dollars, of each smaller container.\nChoice B is incorrect. This expression represents the total sales, in dollars, from selling y larger containers of yogurt.\nChoice C is incorrect. This value represents the price, in dollars, of each larger container of yogurt.\nChoice D is incorrect. This expression represents the total sales, in dollars, from selling x smaller containers of yogurt."}, {"id": "opensat-math-mcq-73", "text": "Theresa ran on a treadmill for thirty minutes, and her time and speed are shown on the graph above. According to the graph, which of the following statements is NOT true concerning Theresa\u2019s run?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["Theresa ran at a constant speed for five minutes.", "Theresa\u2019s speed was increasing for a longer period of time than it was decreasi
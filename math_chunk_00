INSERT INTO sat_tests (title, description, test_type, difficulty, length, section, is_official, time_limit_minutes, questions) VALUES ('OpenSAT Math - Easy Set 1','Official-style SAT Math practice (Easy) from OpenSAT — image-free questions only.','math','easy','medium','math',true,38,'[{"id": "opensat-math-mcq-1", "text": "Which expression is equivalent to 11 x cubed minus 5 x cubed?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["16 x cubed", "6 x cubed", "6 x Superscript 6", "16 x Superscript 6"], "correct_answer": "B", "difficulty": "easy", "explanation": "Choice B is correct. The given expression can be rewritten as 11 x cubed plus left parenthesis negative 5 right parenthesis x cubed. Since the two terms of this expression are both constant multiples of x cubed, they are like terms and can, therefore, be combined through addition. Adding like terms in the expression 11 x cubed plus left parenthesis negative 5 right parenthesis x cubed yields 6 x cubed.\nChoice A is incorrect. This is equivalent to 11 x cubed plus 5 x cubed, not 11 x cubed minus 5 x cubed.\nChoice C is incorrect. This is equivalent to 11 x Superscript 6 minus 5 x Superscript 6, not 11 x cubed minus 5 x cubed. \nChoice D is incorrect. This is equivalent to 11 x Superscript 6 plus 5 x Superscript 6, not 11 x cubed minus 5 x cubed."}, {"id": "opensat-math-mcq-2", "text": "A market researcher selected 200 people at random from a group of people who indicated that they liked a certain book. The 200 people were shown a movie based on the book and then asked whether they liked or disliked the movie. Of those surveyed, 95% said they disliked the movie. Which of the following inferences can appropriately be drawn from this survey result?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["At least 95% of people who go see movies will dislike this movie.", "At least 95% of people who read books will dislike this movie.", "Most people who dislike this book will like this movie.", "Most people who like this book will dislike this movie."], "correct_answer": "D", "difficulty": "easy", "explanation": "Choice D is correct. The sample was selected from a group of people who indicated that they liked the book. It is inappropriate to generalize the result of the survey beyond the population from which the participants were selected. Choice D is the most appropriate inference from the survey results because it describes a conclusion about people who liked the book, and the results of the survey indicate that most people who like the book disliked the movie.Choices A, B, and C are incorrect because none of these inferences can be drawn from the survey results. Choices A and B need not be true. The people surveyed all liked the book on which the movie was based, which is not necessarily true of all people who go see movies or all people who read books. Thus, the people surveyed are not representative of all people who go see movies or all people who read books. Therefore, the results of this survey cannot appropriately be extended to at least 95% of people who go see movies or to at least 95% of people who read books. Choice C need not be true because the sample includes only people who liked the book, and so the results do not extend to people who dislike the book."}, {"id": "opensat-math-mcq-5", "text": "Of 900,000 beads, 828,000 are silver. What percentage of the beads are silver?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["8 percent sign", "36 percent sign", "72 percent sign", "92 percent sign"], "correct_answer": "D", "difficulty": "easy", "explanation": "Choice D is correct. The proportion of the beads that are silver can be written as StartFraction 828,000 Over 900,000 EndFraction, or 0.92. Therefore, the percentage of the beads that are silver is 0.92 left parenthesis 100 right parenthesis, or 92 percent sign.\nChoice A is incorrect. This is the percentage of the beads that are not silver.\nChoice B is incorrect and may result from conceptual or calculation errors.\nChoice C is incorrect and may result from conceptual or calculation errors."}, {"id": "opensat-math-mcq-8", "text": "The length of the base of a certain parallelogram is 89 percent sign of the height of the parallelogram. Which expression represents the length of the base of the parallelogram, where h is the height of the parallelogram?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["89 h", "0.089 h", "8.9 h", "0.89 h"], "correct_answer": "D", "difficulty": "easy", "explanation": "Choice D is correct. It''s given that the length of the base of the parallelogram is 89 percent sign of the height of the parallelogram. Since h is the height of the parallelogram, it follows that the length of the base of the parallelogram can be represented by the expression StartFraction 89 Over 100 EndFraction h, or 0.89 h.\nChoice A is incorrect. This expression represents 8,900 percent sign, not 89 percent sign, of the height of the parallelogram.\nChoice B is incorrect. This expression represents 8.9 percent sign, not 89 percent sign, of the height of the parallelogram.\nChoice C is incorrect. This expression represents 890 percent sign, not 89 percent sign, of the height of the parallelogram."}, {"id": "opensat-math-mcq-11", "text": "*{stroke-linecap:butt;stroke-linejoin:round;}\n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n \n\n \n \n \n \n \n \n \n .small { font: italic 13px Crimson; }\n .heavy { font: bold 30px sans-serif; }\n\n /* Note that the color of the text is set with the *\n * fill property, the color property is for HTML only */\n .Rrrrr { font: italic 40px serif; fill: red; }\n \n \n\n \n\nOne angle is a right angle.\nThe measure of a second angle is x\u00b0.\nThe length of the leg opposite the angle with measure x\u00b0 is 26.\nThe length of the leg adjacent to the angle with measure x\u00b0 is 7.\nA note indicates the figure is not drawn to scale.\n\nIn the triangle shown, what is the value of tangent x degree?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["one twenty sixth", "StartFraction 19 Over 26 EndFraction", "StartFraction 26 Over 7 EndFraction", "StartFraction 33 Over 7 EndFraction"], "correct_answer": "C", "difficulty": "easy", "explanation": "Choice C is correct. The tangent of an acute angle in a right triangle is defined as the ratio of the length of the side opposite the angle to the length of the shorter side adjacent to the angle. In the triangle shown, the length of the side opposite the angle with measure x degree is 26 units and the length of the side adjacent to the angle with measure x degree is 7 units. Therefore, the value of tangent x degree is StartFraction 26 Over 7 EndFraction.\nChoice A is incorrect and may result from conceptual or calculation errors.\nChoice B is incorrect and may result from conceptual or calculation errors.\nChoice D is incorrect and may result from conceptual or calculation errors."}, {"id": "opensat-math-mcq-13", "text": "The table gives the distribution of votes for a new school mascot and grade level for 80 students.\n\nMascot\nGrade level\n\nSixth\nSeventh\nEighth\nTotal\n\nBadger\n4\n9\n9\n22\n\nLion\n9\n2\n9\n20\n\nLonghorn\n4\n6\n4\n14\n\nTiger\n6\n9\n9\n24\n\nTotal\n23\n26\n31\n80\n\nIf one of these students is selected at random, what is the probability of selecting a student whose vote for new mascot was for a lion?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["one ninth", "one fifth", "one fourth", "two thirds"], "correct_answer": "C", "difficulty": "easy", "explanation": "Choice C is correct. If one of these students is selected at random, the probability of selecting a student whose vote for the new mascot was for a lion is given by the number of votes for a lion divided by the total number of votes. The given table indicates that the number of votes for a lion is 20 votes, and the total number of votes is 80 votes. The table gives the distribution of votes for 80 students, and the table shows a total of 80 votes were counted. It follows that each of the 80 students voted exactly once. Thus, the probability of selecting a student whose vote for the new mascot was for a lion is StartFraction 20 Over 80 EndFraction, or one fourth.\nChoice A is incorrect and may result from conceptual or computational errors.\nChoice B is incorrect and may result from conceptual or computational errors.\nChoice D is incorrect and may result from conceptual or computational errors."}, {"id": "opensat-math-mcq-15", "text": "Marta has 7,500 pesos she will convert to US dollars using a currency exchange service. At this time, the currency exchange rate is 1 peso = 0.075 US dollars. The exchange service will charge Marta a 2% fee on the converted US dollar amount. How many US dollars will Marta receive from the currency exchange after the 2% fee is applied?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["$551.25", "$562.50", "$5,625.00", "$98,000.00"], "correct_answer": "A", "difficulty": "easy", "explanation": "Choice A is correct. At the exchange rate of 1 peso = 0.075 US dollars, 7,500 pesos would be converted to 7,500 \u00d7 0.075 = $562.50. However, since Maria pays a 2% fee on the converted US dollar amount, she receives only (100 \u2013 2)%, or 98%, of the converted US dollars, and 562.50 \u00d7 0.98 = $551.25.Choice B is incorrect. This is the number of US dollars Maria would receive if the exchange service did not charge a 2% fee. Choice C is incorrect and may result from a decimal point error made when calculating the conversion to US dollars and from not assessing the 2% fee. Choice D is incorrect and may result from reversing the units of the exchange rate."}, {"id": "opensat-math-mcq-16", "text": "Shaquan has 7 red cards and 28 blue cards. What is the ratio of red cards to blue cards that Shaquan has?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["1 to 4", "4 to 1", "1 to 7", "7 to 1"], "correct_answer": "A", "difficulty": "easy", "explanation": "Choice A is correct. It\u2019s given that Shaquan has 7 red cards and 28 blue cards. Therefore, the ratio of red cards to blue cards that Shaquan has is 7 to 28. This ratio can be reduced by dividing both parts of the ratio by 7, which yields the ratio 1 to 4.Choice B is incorrect. This is the ratio of blue cards to red cards that Shaquan has. Choice C is incorrect and may result from a calculation error when reducing the ratio. Choice D is incorrect. This may result from finding the ratio of blue cards to red cards, or 28 to 7, and then making a calculation error when reducing the ratio."}, {"id": "opensat-math-mcq-19", "text": "The ratio x to y is equivalent to the ratio 12 to t. When x equals 156, what is the value of y in terms of t?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["13 t", "12 t", "144 t", "168 t"], "correct_answer": "A", "difficulty": "easy", "explanation": "Choice A is correct. It''s given that the ratio x to y is equivalent to the ratio 12 to t. This can be represented by StartFraction x Over y EndFraction equals StartFraction 12 Over t EndFraction. Substituting 156 for x in this equation yields StartFraction 156 Over y EndFraction equals StartFraction 12 Over t EndFraction. This can be rewritten as 12 y equals 156 t. Dividing both sides of this equation by 12 yields y equals 13 t. Therefore, when x equals 156, the value of y in terms of t is 13 t.\nChoice B is incorrect and may result from conceptual or calculation errors.\nChoice C is incorrect and may result from conceptual or calculation errors.\nChoice D is incorrect and may result from conceptual or calculation errors."}, {"id": "opensat-math-mcq-21", "text": "4 x plus 6 equals 18\nWhich equation has the same solution as the given equation?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["4 x equals 108", "4 x equals 24", "4 x equals 12", "4 x equals 3"], "correct_answer": "C", "difficulty": "easy", "explanation": "Choice C is correct. Subtracting 6 from both sides of the given equation yields 4 x equals 12, which is the equation given in choice C. Since this equation is equivalent to the given equation, it has the same solution as the given equation.\nChoice A is incorrect and may result from conceptual or calculation errors.\nChoice B is incorrect and may result from conceptual or calculation errors.\nChoice D is incorrect and may result from conceptual or calculation errors."}, {"id": "opensat-math-mcq-27", "text": "Connor has c dollars and Maria has m dollars. Connor has 4 times as many dollars as Maria, and together they have a total of dollar sign 25.00. Which system of equations represents this situation?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["c equals 4 m\nc plus m equals 25", "m equals 4 c\nc plus m equals 25", "c equals 25 m\nc plus m equals 4", "m equals 25 c\nc plus m equals 4"], "correct_answer": "A", "difficulty": "easy", "explanation": "Choice A is correct. It\u2019s given that Connor has c dollars, Maria has m dollars, and Connor has 4 times as many dollars as Maria. This can be represented by the equation c equals 4 m. It\u2019s also given that together, Connor and Maria have a total of dollar sign 25.00, which can be represented by the equation c plus m equals 25. Therefore, the system consisting of the equations c equals 4 m and c plus m equals 25 represents this situation.\nChoice B is incorrect. The equation m equals 4 c represents a situation where Maria has 4 times as many dollars as Connor, rather than the situation where Connor has 4 times as many dollars as Maria.\nChoice C is incorrect. The equation c equals 25 m represents a situation where Connor has 25 times, rather than 4 times, as many dollars as Maria. The equation c plus m equals 4 represents a situation where Connor and Maria together have a total of dollar sign 4.00, rather than dollar sign 25.00.\nChoice D is incorrect. The equation m equals 25 c represents a situation where Maria has 25 times as many dollars as Connor, rather than the situation where Connor has 4 times as many dollars as Maria. The equation c plus m equals 4 represents a situation where Connor and Maria together have a total of dollar sign 4.00, rather than dollar sign 25.00."}, {"id": "opensat-math-mcq-29", "text": "A fish swam a distance of 5,104 yards. How far did the fish swim, in miles? left parenthesis 1 mile equals 1,760 yards right parenthesis", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["0.3", "2.9", "3,344", "6,864"], "correct_answer": "B", "difficulty": "easy", "explanation": "Choice B is correct. It\u2019s given that the fish swam 5,104 yards and that 1 mile is equal to 1,760 yards. Therefore, the fish swam 5,104 yards left parenthesis StartFraction 1 mile Over 1 comma 760 yards EndFraction right parenthesis, which is equivalent to StartFraction 5 comma 104 Over 1 comma 760 EndFraction miles, or 2.9 miles. \nChoice A is incorrect and may result from conceptual or calculation errors.\nChoice C is incorrect and may result from conceptual or calculation errors.\nChoice D is incorrect and may result from conceptual or calculation errors."}, {"id": "opensat-math-mcq-30", "text": "Which expression is equivalent to 8 plus d squared plus 3?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["d squared plus 24", "d squared plus 11", "d squared plus 5", "d squared minus 11"], "correct_answer": "B", "difficulty": "easy", "explanation": "Choice B is correct. The given expression can be rewritten as d squared plus 8 plus 3. Adding 8 and 3 in this expression yields d squared plus 11.\nChoice A is incorrect. This expression is equivalent to d squared plus 8 left parenthesis 3 right parenthesis.\nChoice C is incorrect. This expression is equivalent to 8 plus d squared minus 3.\nChoice D is incorrect. This expression is equivalent to negative 8 plus d squared minus 3."}, {"id": "opensat-math-mcq-31", "text": "The total cost, in dollars, to rent a surfboard consists of a dollar sign 25 service fee and a dollar sign 10 per hour rental fee. A person rents a surfboard for t hours and intends to spend a maximum of dollar sign 75 to rent the surfboard. Which inequality represents this situation?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["10 t less than or equals 75", "10 plus 25 t less than or equals 75", "25 t less than or equals 75", "25 plus 10 t less than or equals 75"], "correct_answer": "D", "difficulty": "easy", "explanation": "Choice D is correct. The cost of the rental fee depends on the number of hours the surfboard is rented. Multiplying t hours by 10 dollars per hour yields a rental fee of 10 t dollars. The total cost of the rental consists of the rental fee plus the 25 dollar service fee, which yields a total cost of 25 plus 10 t dollars. Since the person intends to spend a maximum of 75 dollars to rent the surfboard, the total cost must be at most 75 dollars. Therefore, the inequality 25 plus 10 t less than or equals 75 represents this situation.\nChoice A is incorrect. This represents a situation where the rental fee, not the total cost, is at most 75 dollars.\nChoice B is incorrect and may result from conceptual or calculation errors.\nChoice C is incorrect and may result from conceptual or calculation errors."}, {"id": "opensat-math-mcq-35", "text": "Which expression is a factor of 2 x squared plus 38 x plus 10?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["2", "5 x", "38 x", "2 x squared"], "correct_answer": "A", "difficulty": "easy", "explanation": "Choice A is correct. Since 2 is a common factor of each of the terms in the given expression, the expression can be rewritten as 2 left parenthesis x squared plus 19 x plus 5 right parenthesis. Therefore, the factors of the given expression are 2 and x squared plus 19 x plus 5. Of these two factors, only 2 is listed as a choice.\nChoice B is incorrect and may result from conceptual or calculation errors.\nChoice C is incorrect. This is a term of the given expression, not a factor of the given expression.\nChoice D is incorrect. This is a term of the given expression, not a factor of the given expression."}, {"id": "opensat-math-mcq-36", "text": "x plus y equals 18\n5 y equals x\nWhat is the solution left parenthesis x comma y right parenthesis to the given system of equations?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["left parenthesis 15 comma 3 right parenthesis", "left parenthesis 16 comma 2 right parenthesis", "left parenthesis 17 comma 1 right parenthesis", "left parenthesis 18 comma 0 right parenthesis"], "correct_answer": "A", "difficulty": "easy", "explanation": "Choice A is correct. The second equation in the given system defines the value of x as 5 y. Substituting 5 y for x into the first equation yields 5 y plus y equals 18 or 6 y equals 18. Dividing each side of this equation by 6 yields y equals 3. Substituting 3 for y in the second equation yields 5 left parenthesis 3 right parenthesis equals x or x equals 15. Therefore, the solution left parenthesis x comma y right parenthesis to the given system of equations is left parenthesis 15 comma 3 right parenthesis. \nChoice B is incorrect. Substituting 16 for x and 2 for y in the second equation yields 5 left parenthesis 2 right parenthesis equals 16, which is not true. Therefore, left parenthesis 16 comma 2 right parenthesis is not a solution to the given system of equations.\nChoice C is incorrect. Substituting 17 for x and 1 for y in the second equation yields 5 left parenthesis 1 right parenthesis equals 17, which is not true. Therefore, left parenthesis 17 comma 1 right parenthesis is not a solution to the given system of equations.\nChoice D is incorrect. Substituting 18 for x and 0 for y in the second equation yields 5 left parenthesis 0 right parenthesis equals 18, which is not true. Therefore, left parenthesis 18 comma 0 right parenthesis is not a solution to the given system of equations."}, {"id": "opensat-math-mcq-38", "text": "Clockwise from top left, the 3 lines are labeled t, m, and n.\nLine t intersects both line m and line n.\nAt the intersection of line t and line m, 1 angle is labeled clockwise from top left as follows:\n\nBottom left: 170\u00b0\n\nAt the intersection of line t and line n, 1 angle is labeled clockwise from top left as follows:\n\nBottom left: w\u00b0\n\nA note indicates the figure is not drawn to scale.\n\nIn the figure, line m is parallel to line n. What is the value of w?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["17", "30", "70", "170"], "correct_answer": "D", "difficulty": "easy", "explanation": "Choice D is correct. It''s given that lines m and n are parallel. Since line t intersects both lines m and n, it''s a transversal. The angles in the figure marked as 170 degree and w degree are on the same side of the transversal, where one is an interior angle with line m as a side, and the other is an exterior angle with line n as a side. Thus, the marked angles are corresponding angles. When two parallel lines are intersected by a transversal, corresponding angles are congruent and, therefore, have equal measure. It follows that w degree equals 170 degree. Therefore, the value of w is 170. \nChoice A is incorrect and may result from conceptual or calculation errors.\nChoice B is incorrect and may result from conceptual or calculation errors.\nChoice C is incorrect and may result from conceptual or calculation errors."}, {"id": "opensat-math-mcq-41", "text": "The length, y, of a white whale was 162 centimeters left parenthesis cm right parenthesis when it was born and increased an average of 4.8 cm per month for the first 12 months after it was born. Which equation best represents this situation, where x is the number of months after the whale was born and y is the length, in cm, of the whale?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["y equals 162 x", "y equals 162 x plus 162", "y equals 4.8 x plus 4.8", "y equals 4.8 x plus 162"], "correct_answer": "D", "difficulty": "easy", "explanation": "Choice D is correct. It''s given that the length of the whale was 162 cm when it was born and that its length increased an average of 4.8 cm per month for the first 12 months after it was born. Since x represents the number of months after the whale was born, the total increase in the whale''s length, in cm, is 4.8 times x, or 4.8 x. The length of the whale y, in cm, can be found by adding the whale''s length at birth, 162 cm, to the total increase in length, 4.8 x cm. Therefore, the equation that best represents this situation is y equals 4.8 x plus 162.\nChoice A is incorrect and may result from conceptual errors.\nChoice B is incorrect and may result from conceptual errors.\nChoice C is incorrect and may result from conceptual errors."}, {"id": "opensat-math-mcq-44", "text": "Data set X: 5, 9, 9, 13\nData set Y: 5, 9, 9, 13, 27\nThe lists give the values in data sets X and Y. Which statement correctly compares the mean of data set X and the mean of data set Y?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["The mean of data set X is greater than the mean of data set Y.", "The mean of data set X is less than the mean of data set Y.", "The means of data set X and data set Y are equal.", "There is not enough information to compare the means."], "correct_answer": "B", "difficulty": "easy", "explanation": "Choice B is correct. \u200b\u200bThe mean of a data set is the sum of the values in the data set divided by the number of values in the data set. It follows that the mean of data set X is StartFraction 5 plus 9 plus 9 plus 13 Over 4 EndFraction, or 9, and the mean of data set Y is StartFraction 5 plus 9 plus 9 plus 13 plus 27 Over 5 EndFraction, or 12.6. Since 9 is less than 12.6, the mean of data set X is less than the mean of data set Y.\nAlternate approach: Data set Y consists of the 4 values in data set X and one additional value, 27. Since the additional value, 27, is larger than any value in data set X, the mean of data set X is less than the mean of data set Y.\nChoice A is incorrect and may result from conceptual or calculation errors.\nChoice C is incorrect and may result from conceptual or calculation errors.\nChoice D is incorrect and may result from conceptual or calculation errors."}, {"id": "opensat-math-mcq-47", "text": "What length, in centimeters, is equivalent to a length of 51 meters? left parenthesis 1 meter equals 100 centimeters right parenthesis", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["0.051", "0.51", "5,100", "51,000"], "correct_answer": "C", "difficulty": "easy", "explanation": "Choice C is correct. Since 1 meter is equal to 100 centimeters, 51 meters is equal to 51 meters left parenthesis StartFraction 100 centimeters Over 1 meter EndFraction right parenthesis, or 5,100 centimeters. \nChoice A is incorrect and may result from conceptual or calculation errors.\nChoice B is incorrect and may result from dividing, rather than multiplying, 51 by 100.\nChoice D is incorrect. This is the length, in millimeters rather than centimeters, that is equivalent to a length of 51 meters."}, {"id": "opensat-math-mcq-49", "text": "The number y is 84 less than the number x. Which equation represents the relationship between x and y?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["y equals x plus 84", "y equals one eighty fourth x", "y equals 84 x", "y equals x minus 84"], "correct_answer": "D", "difficulty": "easy", "explanation": "Choice D is correct. It\u2019s given that the number y is 84 less than the number x. A number that''s 84 less than the number x is equivalent to 84 subtracted from the number x, or x minus 84. Therefore, the equation y equals x minus 84 represents the relationship between x and y.\nChoice A is incorrect and may result from conceptual errors.\nChoice B is incorrect and may result from conceptual errors.\nChoice C is incorrect and may result from conceptual errors."}, {"id": "opensat-math-mcq-51", "text": "What is 10 percent sign of 470?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["37", "47", "423", "460"], "correct_answer": "B", "difficulty": "easy", "explanation": "Choice B is correct. 10 percent sign of a quantity means StartFraction 10 Over 100 EndFraction times the quantity. Therefore, 10 percent sign of 470 can be represented as StartFraction 10 Over 100 EndFraction left parenthesis 470 right parenthesis, which is equivalent to 0.10 left parenthesis 470 right parenthesis, or 47. Therefore, 10 percent sign of 470 is 47.\nChoice A is incorrect. This is 10 percent sign of 370, not 10 percent sign of 470.\nChoice C is incorrect. This is 90 percent sign of 470, not 10 percent sign of 470.\nChoice D is incorrect. This is 470 minus 10, not 10 percent sign of 470."}, {"id": "opensat-math-mcq-54", "text": "The function g is defined by g left parenthesis x right parenthesis equals 10 x plus 8. What is the value of g left parenthesis x right parenthesis when x equals 8?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["0", "8", "10", "88"], "correct_answer": "D", "difficulty": "easy", "explanation": "Choice D is correct. The value of g left parenthesis x right parenthesis when x equals 8 can be found by substituting 8 for x in the given equation g left parenthesis x right parenthesis equals 10 x plus 8. This yields g left parenthesis 8 right parenthesis equals 10 left parenthesis 8 right parenthesis plus 8, or g left parenthesis 8 right parenthesis equals 88. Therefore, when x equals 8, the value of g left parenthesis x right parenthesis is 88.\nChoice A is incorrect. This is the value of x when g left parenthesis x right parenthesis equals 8, rather than the value of g left parenthesis x right parenthesis when x equals 8.\nChoice B is incorrect and may result from conceptual or calculation errors.\nChoice C is incorrect and may result from conceptual or calculation errors."}, {"id": "opensat-math-mcq-55", "text": "Which expression is equivalent to 12 x cubed minus 5 x cubed?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["7 x Superscript 6", "17 x cubed", "7 x cubed", "17 x Superscript 6"], "correct_answer": "C", "difficulty": "easy", "explanation": "Choice C is correct. The given expression shows subtraction of two like terms. The two terms can be subtracted as follows: 12 x cubed minus 5 x cubed equals left parenthesis 12 minus 5 right parenthesis x cubed, or 7 x cubed.\nChoice A is incorrect and may result from conceptual or calculation errors.\nChoice B is incorrect. This is the result of adding, not subtracting, the two like terms.\nChoice D is incorrect and may result from conceptual or calculation errors."}, {"id": "opensat-math-mcq-56", "text": "If 4 x plus 2 equals 12, what is the value of 16 x plus 8?", "type": "multiple_choice", "topic": "math", "section": "math", "options": ["40", "48", "56", "60"], "correct_answer": "B", "difficulty": "easy", "explanation": "Choice B is correct. Multiplying both sides of the given equation by 4 yields left parenthesis 4 right parenthesis left parenthesis 4 x plus 2 right parenthesis equals left parenthesis 4 right parenthesis left parenthesis 12 right parenthesis, or 16 x plus 8 equals 48. Therefore, the value of 16 x plus 8 is 48.\nChoice A is incorrect and may resu
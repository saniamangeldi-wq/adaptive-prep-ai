INSERT INTO sat_tests (title, description, test_type, difficulty, length, section, is_official, time_limit_minutes, questions) VALUES ('OpenSAT Math - Hard Set 7','Official-style SAT Math practice (Hard) from OpenSAT — image-free questions only.','math','hard','medium','math',true,38,'[{"id": "opensat-math-spr-557", "text": "A circle has center upper O, and points upper R and upper S lie on the circle. In triangle upper O upper R upper S, the measure of angle upper R upper O upper S is 88 degree. What is the measure of angle upper R upper S upper O, in degrees? (Disregard the degree symbol when entering your answer.)", "type": "grid_in", "topic": "math", "section": "math", "correct_answer": "46", "difficulty": "hard", "explanation": "The correct answer is 46. It''s given that upper O is the center of a circle and that points upper R and upper S lie on the circle. Therefore, ModifyingAbove upper O upper R With bar and ModifyingAbove upper O upper S With bar are radii of the circle. It follows that upper O upper R equals upper O upper S. If two sides of a triangle are congruent, then the angles opposite them are congruent. It follows that the angles angle upper R upper S upper O and angle upper O upper R upper S, which are across from the sides of equal length, are congruent. Let x degree represent the measure of angle upper R upper S upper O. It follows that the measure of angle upper O upper R upper S is also x degree. It''s given that the measure of angle upper R upper O upper S is 88 degree. Because the sum of the measures of the interior angles of a triangle is 180 degree, the equation x degree plus x degree plus 88 degree equals 180 degree, or 2 x plus 88 equals 180, can be used to find the measure of angle upper R upper S upper O. Subtracting 88 from both sides of this equation yields 2 x equals 92. Dividing both sides of this equation by 2 yields x equals 46. Therefore, the measure of angle upper R upper S upper O, in degrees, is 46."}, {"id": "opensat-math-sp